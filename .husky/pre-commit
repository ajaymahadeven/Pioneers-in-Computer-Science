#!/bin/sh

echo '✈️  PRE-FLIGHT CHECKLIST - Preparing for takeoff...\n'

# Check Prettier standards
echo '📋 [1/3] Checking code formatting...'
npm run format:check ||
(
    echo '\n❌ FORMATTING CHECK FAILED
    └─ Code style does not meet standards
    └─ Run: npm run format
    └─ Then: git add . && git commit again\n';
    false;
)
echo '✓ Code formatting passed\n'

# Check ESLint Standards
echo '📋 [2/3] Running ESLint checks...'
npm run lint ||
(
    echo '\n❌ LINTING CHECK FAILED
    └─ Fix the issues listed above
    └─ Then: git add . && git commit again\n'
    false;
)
echo '✓ ESLint passed\n'

# Check tsconfig standards
echo '📋 [3/3] Running TypeScript type checks...'
npm run typecheck ||
(
    echo '\n❌ TYPE CHECK FAILED
    └─ Fix type errors listed above
    └─ Then: git add . && git commit again\n'
    false;
)
echo '✓ Type checking passed\n'

